# ─── SERVER ────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── DATABASE ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nexus_db

# ─── AUTH ──────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=30d

# ─── AI PROVIDERS ──────────────────────────────────────
OPENAI_API_KEY=sk-...AeoA
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ─── RATE LIMITING ─────────────────────────────────────
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=30

# ─── FRONTEND ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
